# MCP Server Auth
MCP_AUTH_TOKEN=your-bearer-token-here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Contentful (scoped bot token — entries.create and entries.update only)
CONTENTFUL_MANAGEMENT_TOKEN=your-scoped-token
CONTENTFUL_SPACE_ID=7nlepvg580vx
CONTENTFUL_ENVIRONMENT_ID=master

# Search thresholds (optional — these are the defaults)
SEARCH_MATCH_THRESHOLD=0.78
COVERAGE_MATCH_THRESHOLD=0.85

# Voyage AI (for embedding search queries)
VOYAGE_API_KEY=your-voyage-api-key

# Optional additional allowed origin for MCP connections
ALLOWED_ORIGIN=

# Server
PORT=3000
